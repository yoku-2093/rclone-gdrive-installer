# =====================================================================
# rclone自動マウント設定ファイル
# =====================================================================

# 1. 接続元のリモート名と対象の仮想ディレクトリ (rclone configで設定した名前)
# 例: gdrive: や gdrive:album/MyAlbum など
GDRIVE_DIR=gdrive:

# 2. マウント先となるローカルのフォルダ名（ホームディレクトリ配下に作られます）
# 例: google_photos や Pictures/GooglePhotos など、自由に指定可能
LOCAL_MOUNT_DIR=google_photos
